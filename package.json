{
  "name": "hk-kindergarten-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "npx prisma generate && npx prisma db push --accept-data-loss && tsc",
    "start": "node dist/index.js",
    "render-build": "node render-build.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "import:kindergartens": "ts-node src/scripts/importKindergartens.ts",
    "import:gov:kgp": "ts-node src/scripts/importGovKgp.ts",
    "sync:google-ratings": "ts-node src/scripts/syncGoogleRatings.ts",
    "prelaunch:check": "powershell -ExecutionPolicy Bypass -File scripts/prelaunch-check.ps1"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "body-parser": "^1.20.2",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.15",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "^6.0.0",
    "ts-node": "^10.9.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "typescript": "5.4.3"
  }
}
