PORT=3001
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3001
JWT_SECRET=replace-with-a-secure-random-string
DATABASE_URL="file:./dev.db"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=

# CAPTCHA (turnstile or recaptcha)
CAPTCHA_PROVIDER=recaptcha
CAPTCHA_SECRET_KEY=
CAPTCHA_SITE_KEY=

# Email OTP verification
EMAIL_OTP_SECRET=replace-with-another-secure-random-string
REQUIRE_EMAIL_VERIFIED=true

# SMTP for verification emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Rate limits
REVIEW_RATE_LIMIT_WINDOW_MS=900000
REVIEW_RATE_LIMIT_MAX=5
EMAIL_OTP_SEND_WINDOW_MS=600000
EMAIL_OTP_SEND_MAX=3
EMAIL_OTP_VERIFY_WINDOW_MS=600000
EMAIL_OTP_VERIFY_MAX=10
